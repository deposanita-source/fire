<script>
const PRIORITY={AMBALAJ:1,YRDMALZM:2,HAMMADDE:3,MAMUL:4};

const raw=document.getElementById("rawData").value.trim();
let stocks=raw.split("\n").map(l=>{
  const p=l.split("\t");
  return{grup:p[0],code:p[1],name:p.slice(2).join(" ")};
});

/* DEDUP */
const map={};
stocks.forEach(s=>{
  if(!map[s.code]||PRIORITY[s.grup]<PRIORITY[map[s.code].grup]){
    map[s.code]=s;
  }
});
stocks=Object.values(map);

const norm=s=>s.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"").replace(/ı/g,"i");

const input=document.getElementById("search");
const list=document.getElementById("list");
const tabs=document.querySelectorAll(".tab");
let activeTab="ALL";
let lastVib=null;

tabs.forEach(t=>{
  t.onclick=()=>{
    tabs.forEach(x=>x.classList.remove("active"));
    t.classList.add("active");
    activeTab=t.dataset.tab;
    render();
  };
});

function score(s,q){
  q=norm(q);
  if(norm(s.code)===q||norm(s.name)===q) return 100;
  if(norm(s.code).startsWith(q)||norm(s.name).startsWith(q)) return 80;
  if(norm(s.code).includes(q)||norm(s.name).includes(q)) return 50;
  return 0;
}

function vibrate(code){
  if(code===lastVib) return;
  lastVib=code;
  navigator.vibrate?.([200,80,200,80,300]);
}

function render(){
  const q=input.value.trim();
  list.innerHTML="";
  if(!q){lastVib=null;return;}

  stocks
    .map(s=>({...s,score:score(s,q)}))
    .filter(s=>s.score>0)
    .filter(s=>{
      if(activeTab==="ALL") return true;
      if(activeTab==="AMBALAJ") return s.grup==="AMBALAJ"||s.grup==="YRDMALZM";
      return s.grup===activeTab;
    })
    .sort((a,b)=>b.score-a.score)
    .forEach((s,i)=>{
      const exact=s.score>=95;
      const c=document.createElement("div");
      c.className="card"+(exact?" exact":"");
      c.innerHTML=`
        <span class="badge">${s.grup}</span>
        <div class="code">${s.code}</div>
        <div class="name">${s.name}</div>`;
      list.appendChild(c);
      if(i===0&&exact) vibrate(s.code);
    });
}

input.addEventListener("input",render);
</script>
